<!doctype html>
<html lang="zh-CN">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>FinTwit 每日简报 - {{ date }}</title>
  <style>
    :root {
      --bg: #f6f7f9;
      --panel: #ffffff;
      --panel-soft: #f0f4f8;
      --text: #17202a;
      --muted: #657282;
      --line: #d9e0e8;
      --green: #147d4f;
      --red: #b42318;
      --amber: #9a6700;
      --blue: #1f5fbf;
      --chip: #e8edf4;
    }

    * { box-sizing: border-box; }
    body {
      margin: 0;
      background: var(--bg);
      color: var(--text);
      font: 14px/1.55 -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    }
    a { color: var(--blue); text-decoration: none; }
    a:hover { text-decoration: underline; }

    .page {
      max-width: 1180px;
      margin: 0 auto;
      padding: 28px 18px 56px;
    }
    header {
      padding: 18px 0 22px;
      border-bottom: 1px solid var(--line);
    }
    h1 {
      margin: 0 0 8px;
      font-size: 30px;
      line-height: 1.2;
      letter-spacing: 0;
    }
    .meta {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      color: var(--muted);
    }
    .pill {
      display: inline-flex;
      align-items: center;
      min-height: 26px;
      padding: 3px 9px;
      border: 1px solid var(--line);
      border-radius: 999px;
      background: var(--panel);
      white-space: nowrap;
    }
    .disclaimer {
      margin-top: 14px;
      max-width: 860px;
      color: var(--muted);
    }

    section {
      margin-top: 22px;
    }
    h2 {
      margin: 0 0 12px;
      font-size: 18px;
      line-height: 1.3;
      letter-spacing: 0;
    }
    h3 {
      margin: 0 0 10px;
      font-size: 15px;
      line-height: 1.35;
    }
    .grid {
      display: grid;
      grid-template-columns: repeat(12, 1fr);
      gap: 14px;
    }
    .card {
      background: var(--panel);
      border: 1px solid var(--line);
      border-radius: 8px;
      padding: 14px;
    }
    .span-4 { grid-column: span 4; }
    .span-6 { grid-column: span 6; }
    .span-12 { grid-column: span 12; }
    .empty {
      color: var(--muted);
      padding: 10px 0;
    }

    table {
      width: 100%;
      border-collapse: collapse;
      background: var(--panel);
      border: 1px solid var(--line);
      border-radius: 8px;
      overflow: hidden;
    }
    th, td {
      padding: 9px 10px;
      border-bottom: 1px solid var(--line);
      vertical-align: top;
      text-align: left;
    }
    th {
      color: var(--muted);
      background: var(--panel-soft);
      font-weight: 600;
      white-space: nowrap;
    }
    tr:last-child td { border-bottom: 0; }
    .num { text-align: right; }
    .tag {
      display: inline-flex;
      align-items: center;
      min-height: 22px;
      padding: 1px 7px;
      border-radius: 999px;
      background: var(--chip);
      color: #2f3b49;
      font-size: 12px;
      white-space: nowrap;
    }
    .tag.long { color: var(--green); background: #e6f4ec; }
    .tag.short, .tag.risk { color: var(--red); background: #fbeae8; }
    .tag.neutral { color: #4d5966; background: #edf1f5; }
    .tag.topic { color: #174ea6; background: #e8f0fe; }
    .tag.warn { color: var(--amber); background: #fff3cd; }

    .list {
      display: grid;
      gap: 10px;
      margin: 0;
      padding: 0;
      list-style: none;
    }
    .list li {
      padding: 10px;
      border: 1px solid var(--line);
      border-radius: 8px;
      background: var(--panel);
    }
    .small {
      color: var(--muted);
      font-size: 12px;
    }
    .summary-list {
      margin: 8px 0 12px;
      padding-left: 18px;
      color: #2f3b49;
    }

    details {
      border: 1px solid var(--line);
      border-radius: 8px;
      background: var(--panel);
      overflow: hidden;
    }
    details + details { margin-top: 10px; }
    summary {
      cursor: pointer;
      padding: 12px 14px;
      background: var(--panel-soft);
      font-weight: 700;
    }
    .details-body { padding: 12px 14px 14px; }
    .tweet-table { font-size: 13px; }
    .tweet-text { min-width: 260px; }
    footer {
      margin-top: 28px;
      padding-top: 16px;
      border-top: 1px solid var(--line);
      color: var(--muted);
    }

    @media (max-width: 860px) {
      .page { padding: 20px 12px 42px; }
      h1 { font-size: 24px; }
      .span-4, .span-6 { grid-column: span 12; }
      table {
        display: block;
        overflow-x: auto;
        white-space: nowrap;
      }
      .tweet-text {
        min-width: 420px;
        white-space: normal;
      }
    }
  </style>
</head>
<body>
  <main class="page">
    <header>
      <h1>FinTwit 每日简报</h1>
      <div class="meta">
        <span class="pill">{{ date }}</span>
        <span class="pill">常规层 {{ window_hours }} 小时</span>
        <span class="pill">{{ blogger_count }} 位博主</span>
        <span class="pill">{{ tweet_count }} 条常规窗口推文</span>
        {% if weekly_has_any %}<span class="pill">含周度摘要</span>{% endif %}
      </div>
      <div class="disclaimer">{{ disclaimer }}</div>
    </header>

    <section>
      <h2>今日热点</h2>
      {% if topic_heat.length %}
      <table>
        <thead><tr><th>主题</th><th class="num">提及次数</th><th>相关博主</th></tr></thead>
        <tbody>
          {% for t in topic_heat.slice(0, 6) %}
          <tr>
            <td><span class="tag topic">{{ t.topic }}</span></td>
            <td class="num">{{ t.count }}</td>
            <td>{{ t.bloggers.join(", ") }}</td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
      {% else %}<div class="empty">当前窗口内暂无明显热点。</div>{% endif %}
    </section>

    <section>
      <h2>多博主共识</h2>
      <div class="grid">
        <div class="card span-4">
          <h3>做多共识</h3>
          {% if consensus_long.length %}
          <ul class="list">
            {% for c in consensus_long.slice(0, 8) %}
            <li><strong>{{ c.ticker }}</strong> <span class="tag long">分数 {{ c.score }}</span><br><span class="small">{{ c.n_bloggers }} 位博主：{% for b in c.by %}<a href="{{ b.url }}">{{ b.handle }}</a>{% if not loop.last %}，{% endif %}{% endfor %}</span></li>
            {% endfor %}
          </ul>
          {% else %}<div class="empty">今日暂无做多共识。</div>{% endif %}
        </div>
        <div class="card span-4">
          <h3>做空共识</h3>
          {% if consensus_short.length %}
          <ul class="list">
            {% for c in consensus_short.slice(0, 8) %}
            <li><strong>{{ c.ticker }}</strong> <span class="tag short">分数 {{ c.score }}</span><br><span class="small">{{ c.n_bloggers }} 位博主：{% for b in c.by %}<a href="{{ b.url }}">{{ b.handle }}</a>{% if not loop.last %}，{% endif %}{% endfor %}</span></li>
            {% endfor %}
          </ul>
          {% else %}<div class="empty">今日暂无做空共识。</div>{% endif %}
        </div>
        <div class="card span-4">
          <h3>分歧标的</h3>
          {% if divergence.length %}
          <ul class="list">
            {% for d in divergence.slice(0, 5) %}
            <li><strong>{{ d.ticker }}</strong><br><span class="small">做多权重 {{ d.long_w }} vs 做空权重 {{ d.short_w }}</span></li>
            {% endfor %}
          </ul>
          {% else %}<div class="empty">暂无明显分歧。</div>{% endif %}
        </div>
      </div>
    </section>

    <section>
      <h2>仓位/观点变化</h2>
      <div class="grid">
        {% for handle, diff in position_diffs %}
        <div class="card span-6">
          <h3>@{{ handle }}</h3>
          {% if diff.new.length %}<p><strong>新提及：</strong>{% for n in diff.new %}<span class="tag">{{ n.ticker }}</span>{% if not loop.last %} {% endif %}{% endfor %}</p>{% endif %}
          {% if diff.reinforced.length %}<p><strong>强度提升：</strong>{% for r in diff.reinforced %}<span class="tag">{{ r.ticker }} {{ r.from }}→{{ r.to }}</span>{% if not loop.last %} {% endif %}{% endfor %}</p>{% endif %}
          {% if not diff.new.length and not diff.reinforced.length %}<div class="empty">暂无新的仓位信号。</div>{% endif %}
        </div>
        {% endfor %}
      </div>
    </section>

    <section>
      <h2>风险雷达</h2>
      {% if risk.red_flags.length %}
      <ul class="list">
        {% for r in risk.red_flags %}
        <li><strong>{{ r.ticker }}</strong> {% if r.in_long_consensus %}<span class="tag warn">与做多共识重叠</span>{% endif %}
          <ul>
            {% for s in r.risk_sources %}<li><a href="{{ s.url }}">@{{ s.handle }}</a>：{{ s.snippet_zh or s.snippet }}</li>{% endfor %}
          </ul>
        </li>
        {% endfor %}
      </ul>
      {% else %}<div class="empty">今日暂无 ticker 绑定风险提醒。</div>{% endif %}
      {% if risk.generic_risk_posts.length %}
      <h3>泛风险讨论</h3>
      <ul class="list">
        {% for g in risk.generic_risk_posts.slice(0, 5) %}
        <li><a href="{{ g.url }}">@{{ g.handle }}</a>：{{ g.snippet_zh or g.snippet }}</li>
        {% endfor %}
      </ul>
      {% endif %}
    </section>

    <section>
      <h2>回测快照</h2>
      <table>
        <thead><tr><th>博主</th><th class="num">样本数</th><th class="num">30 日胜率</th></tr></thead>
        <tbody>
          {% for h, s in backtest %}
          <tr><td>@{{ h }}</td><td class="num">{{ s.n }}</td><td class="num">{% if s.win_rate_30d !== null %}{{ s.win_rate_30d }}%{% else %}暂无{% endif %}</td></tr>
          {% endfor %}
        </tbody>
      </table>
    </section>

    <section>
      <h2>按博主汇总与详情</h2>
      {% if blogger_summaries.length %}
      {% for b in blogger_summaries %}
      <details>
        <summary>@{{ b.handle }}（{{ b.layer }} · {{ b.count }} 条）</summary>
        <div class="details-body">
          {% if b.highlights.length %}
          <ul class="summary-list">
            {% for h in b.highlights %}<li>{{ h }}</li>{% endfor %}
          </ul>
          {% endif %}
          <table class="tweet-table">
            <thead><tr><th>时间</th><th>观点</th><th>主题</th><th>标的</th><th class="num">浏览</th><th>中文翻译/摘要</th></tr></thead>
            <tbody>
              {% for it in b.items %}
              <tr>
                <td><a href="{{ it.url }}">{{ it.created_at.slice(0, 10) }}</a></td>
                <td><span class="tag {% if it.stance === 'LONG' %}long{% elif it.stance === 'SHORT' %}short{% elif it.stance === 'RISK_FLAG' %}risk{% else %}neutral{% endif %}">{{ it.stance }}</span></td>
                <td><span class="tag topic">{{ it.topic }}</span></td>
                <td>{% if it.tickers.length %}{{ it.tickers.join(" ") }}{% else %}-{% endif %}</td>
                <td class="num">{{ it.view_count }}</td>
                <td class="tweet-text">{{ (it.translation_zh or it.summary_zh or it.text).slice(0, 320) }}</td>
              </tr>
              {% endfor %}
            </tbody>
          </table>
        </div>
      </details>
      {% endfor %}
      {% else %}<div class="empty">暂无可汇总的过滤后推文。</div>{% endif %}
    </section>

    <section>
      <h2>今日高互动推文</h2>
      <ul class="list">
        {% for t in top_tweets.slice(0, 10) %}
        <li><strong><a href="{{ t.url }}">@{{ t.handle }}</a></strong> <span class="small">{{ t.view_count }} 次浏览 · 观点强度 {{ t.conviction }}</span><br>{{ t.translation_zh or t.summary_zh or t.text.slice(0, 280) }}</li>
        {% endfor %}
      </ul>
    </section>

    {% if weekly_has_any %}
    <section>
      <h2>周度摘要：宏观与风险</h2>
      {% for handle, bucket in weekly %}
      <div class="card">
        <h3>@{{ handle }}（{{ bucket.layer }} · {{ bucket.function }}）</h3>
        <ul class="list">
          {% for it in bucket.items.slice(0, 5) %}
          <li><a href="{{ it.url }}">{{ it.created_at.slice(0, 10) }}</a> · {{ it.view_count }} 次浏览 · {{ it.stance }}{% if it.tickers.length %} · {{ it.tickers.join(" ") }}{% endif %}<br>{{ it.translation_zh or it.summary_zh or it.text.slice(0, 240) }}</li>
          {% endfor %}
        </ul>
      </div>
      {% endfor %}
    </section>
    {% endif %}

    <footer>由 FinTwit Tracker 生成 · {{ generated_at }}</footer>
  </main>
</body>
</html>
